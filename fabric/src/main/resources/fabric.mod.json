{
  "schemaVersion": 1,
  "id": "ait",
  "version": "${version}",
  "name": "Adventures in Time",
  "description": "Adventures In Time for 1.21.1 Fabric and Forge!",
  "authors": [
    "AmbleLabs"
  ],
  "contributors": [
  ],
  "contact": {
    "homepage": "https://theo.is-a.dev/"
  },
  "license": "LGPL-3.0",
  "icon": "assets/ait/icon.png",
  "environment": "*",
  "entrypoints": {
    "main": [
      "dev.amble.ait.fabric.FabricAitInit"
    ],
    "client": [
      "dev.amble.ait.fabric.FabricAitClientInit"
    ],
    "fabric-datagen": [
      "dev.amble.ait.fabric.datagen.FabricAitDataGenerators"
    ],
    "modmenu": [
      "dev.amble.ait.fabric.interop.ModMenuInterop"
    ]
  },
  "mixins": [
    "ait.mixins.json",
    "ait-fabric.mixins.json"
  ],
  "accessWidener": "ait-fabric.accesswidener",
  "depends": {
    "fabricloader": "*",
    "minecraft": "~${minecraft_version}",
    "java": ">=17",

    "fabric-api": "*",
    "cloth-config": "15.0.*",
    "patchouli": ">=${minecraft_version}-${patchouli_version}"
  },
  "suggests": {
    "modmenu": "*"
  }
}
